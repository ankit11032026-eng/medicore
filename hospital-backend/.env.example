# ============================================================
# MediCore Hospital — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# MongoDB Atlas Connection String
# Get this from: Atlas Dashboard → Cluster → Connect → Drivers
# Replace <username>, <password>, and <cluster> with your values
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/medicore?retryWrites=true&w=majority

# JWT Secret — change this to a long random string in production
JWT_SECRET=medicore_super_secret_jwt_key_change_in_production_2026

# Admin credentials (used to seed/login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Staff credentials
STAFF_USERNAME=staff
STAFF_PASSWORD=staff123

# Server port
PORT=5000

# Frontend URL (for CORS) — set to your frontend URL in production
CLIENT_URL=http://localhost:3000
